/////////// deepstorage items

/obj/item/paper/fluff/ruins/deepstorage/water_concern
	name = "水资源问题"
	default_raw_text = "致那位一直洗着又长又热水澡的家伙：你被安排去参加下一次的冰矿开采任务。如果你觉得有必要在你那‘放松’时间里用光所有该死的水，那你他妈的就得为所有这些水去干活！"

/obj/item/paper/fluff/ruins/deepstorage/hydro_notice
	name = "水培通知"
	default_raw_text = "水培是我们的生命线，如果它死了，我们也活不成。务必给那些该死的植物浇水！"

/obj/item/paper/fluff/ruins/deepstorage/recycling_notice
	name = "回收通知"
	default_raw_text = "请务必将所有多余的废物扔进后面的粉碎机里！如果你把别人眼中的‘垃圾’放进巨型粉碎机里碾足够多次，你能从中得到的东西会令人惊叹。"

