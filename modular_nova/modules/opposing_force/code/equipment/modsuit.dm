/datum/opposing_force_equipment/modsuit
	category = OPFOR_EQUIPMENT_CATEGORY_MODSUIT

/datum/opposing_force_equipment/modsuit/red
	name = "戈莱克斯掠夺者红色款"
	description = "一套先进的战斗服，饰以不祥的深红色配色方案，专为特殊雇佣兵行动生产和制造。"
	item_type = /obj/item/mod/control/pre_equipped/traitor

/datum/opposing_force_equipment/modsuit/contractor
	name = "私人佣兵模块化宇航服"
	description = "这是辛迪加对其惯用配色方案的一次罕见偏离，这套MOD防护服是为私人雇佣兵生产和制造的。"
	item_type = /obj/item/mod/control/pre_equipped/contractor

/datum/opposing_force_equipment/modsuit/elite
	name = "赛博阳光精英款"
	description = "辛迪加防护服的进化版，采用更庞大的结构和哑光黑色配色方案，此防护服仅生产给高级辛迪加军官和精英突击队。"
	item_type = /obj/item/mod/control/pre_equipped/elite/unrestricted

/datum/opposing_force_equipment/modsuit/ninja
	name = "赛博阳光忍者款"
	description = "一套专为蜘蛛氏族刺客-破坏者设计的纳米增强装甲。这套MOD防护服采用了最尖端的潜行和战斗技术，设计紧身但坚固程度堪比厚度是其两到三倍的防护服。"
	item_type = /obj/item/mod/control/pre_equipped/ninja

/datum/opposing_force_equipment/modsuit/corporate
	name = "中央司令部企业款"
	description = "大亨型号的更昂贵版本，这套企业防护服是为高级中央司令部军官设计的隔热、防腐蚀涂层防护服，部署了原始的保护装甲和先进的致动器，开启时感觉几乎毫无重量。"
	item_type = /obj/item/mod/control/pre_equipped/corporate

/datum/opposing_force_equipment/modsuit/standard
	name = "中村标准款"
	description = "由中村工程公司生产的第三代模块化民用级防护服，这套防护服是整个星系民用领域的标配。"
	item_type = /obj/item/mod/control/pre_equipped/empty

/datum/opposing_force_equipment/modsuit/advanced
	name = "中村的先进型"
	description = "这是中村工程工业型号的旗舰版本，也是他们的最新产品。	它内部集成了其他工业型号的所有功能，其抗爆能力几乎接近某些排爆服，外部则涂有一层据传是公司机密的白色抛光涂层。"
	item_type = /obj/item/mod/control/pre_equipped/advanced

/datum/opposing_force_equipment/modsuit/hc
	name = "HC的日出型"
	item_type = /obj/item/mod/control/pre_equipped/voskhod/ancient_milsim

/datum/opposing_force_equipment/modsuit/hc_patrol
	name = "ZCM的边缘世界巡查员"
	item_type = /obj/item/mod/control/pre_equipped/rim_inspector

/datum/opposing_force_equipment/modsuit/infiltrator
	name = "MI13的渗透者型"
	description = "多年来，关于这款隐秘的“渗透者”模块化护甲，人们提出了几个问题。为什么作为潜行护甲，它却是血红色的？为什么偏偏是一家电影公司开发了这款隐形护甲？	最简单的答案是，Roseus Galactic雇佣了不少古怪的人，他们对视觉美学和道具设计的了解远多于对功能性作战伪装的理解。但真正的原因更为深刻。"
	item_type = /obj/item/mod/control/pre_equipped/infiltrator

/datum/opposing_force_equipment/modsuit/interdyne
	name = "Interdyne的响应型"
	description = "虽然斯卡伯勒和阿齐克星际提供渠道，唐克公司、老虎合作社、动物权利联盟和戈莱克斯掠夺者提供自愿或易被收买的武力，S.E.L.F.和MI13提供情报，但明确的辛迪加技术提供者无疑是Interdyne和Cybersun，他们联合掌握的技术知识只有最神秘的异形才能匹敌，绝非任何纳米传讯的科学家可比。"
	admin_note = "Gives a significant speedboost."
	item_type = /obj/item/mod/control/pre_equipped/interdyne

/datum/opposing_force_equipment/modsuit/clown
	name = "Honk有限公司的宇宙鸣响型"
	description = "宇宙小丑MOD防护服最初设计用于在低幽默环境中进行星际喜剧表演。	它采用钨电陶瓷外壳和铬双极材料，表面涂有锆硼涂料，覆盖在皮肤特拉里安子空间合金之下。尽管其光电子真空驱动踏板显而易见，但这款特定型号并未使用锰双极电容器清洁器，感谢小丑之母。"
	item_type = /obj/item/mod/control/pre_equipped/cosmohonk

/datum/opposing_force_equipment/modsuit/wizard
	name = "神秘赋能MOD"
	description = "巫师联合会相对低科技的MOD防护服。这套护甲采用的不是塑钢或碳纤维，而是太空龙鳞片来提供防护。"
	item_type = /obj/item/mod/control/pre_equipped/enchanted


