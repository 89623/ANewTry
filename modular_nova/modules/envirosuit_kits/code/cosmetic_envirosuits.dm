/// Prototype Envirosuit, renamed Curator suit

/obj/item/clothing/under/plasmaman/prototype
	name = "原型环境防护服"
	desc = "这套由改装过的太空服制成的防护服，是纳米传讯公司为解决雇佣等离子体人带来的*后勤问题*而提出的首个方案。由于改装，这套服装不再适合太空作业。尽管存在这些限制，历史学家和老派等离子体人仍在使用这些服装。"
	icon = 'icons/obj/clothing/under/plasmaman.dmi'
	icon_state = "prototype_envirosuit"

/obj/item/clothing/head/helmet/space/plasmaman/prototype
	name = "原型等离子环境防护服头盔"
	desc = "这款对传统太空服头盔稍作修改的头盔，是纳米传讯公司为解决雇佣等离子体人带来的*后勤问题*而提出的首个方案。尽管存在这些限制，历史学家和老派等离子体人仍在使用这些头盔。"
	icon_state = "prototype_envirohelm"
